{
  "name": "spotify-yt-sync",
  "version": "1.0.0",
  "description": "Automatically sync Spotify playlists to YouTube Music",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "sync": "node dist/index.js --sync",
    "scheduler": "node dist/index.js --start-scheduler",
    "clean": "rm -rf dist logs",
    "clean:windows": "rmdir /s /q dist logs 2>nul || true"
  },
  "keywords": [
    "spotify",
    "youtube",
    "music",
    "sync",
    "playlist",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3",
    "string-similarity": "^4.0.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.9",
    "@types/string-similarity": "^4.0.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
